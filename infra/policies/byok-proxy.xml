<policies>
  <inbound>
    <base />
    <set-variable name="presentedKey" value="@{
        var auth = context.Request.Headers.GetValueOrDefault(&quot;Authorization&quot;, &quot;&quot;);
        return auth.StartsWith(&quot;Bearer &quot;, StringComparison.OrdinalIgnoreCase)
            ? auth.Substring(&quot;Bearer &quot;.Length).Trim()
            : &quot;&quot;;
    }" />
    <choose>
      <when condition="@(string.IsNullOrEmpty((string)context.Variables[&quot;presentedKey&quot;]) || (string)context.Variables[&quot;presentedKey&quot;] != &quot;{{byokClientKey}}&quot;)">
        <return-response>
          <set-status code="401" reason="Unauthorized" />
          <set-header name="WWW-Authenticate" exists-action="override">
            <value>Bearer error="invalid_token"</value>
          </set-header>
          <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
          </set-header>
          <set-body>{"error":{"message":"Invalid or missing API key.","type":"invalid_request_error","code":"invalid_api_key"}}</set-body>
        </return-response>
      </when>
    </choose>
    <set-backend-service backend-id="foundry-backend" />
  </inbound>
  <backend>
    <base />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
